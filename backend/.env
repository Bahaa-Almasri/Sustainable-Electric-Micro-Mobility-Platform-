# Neo n "REST" / https://.../rest/v1 is NOT a database URL — asyncpg needs Postgres wire protocol:
# postgresql://ROLE:PASSWORD@HOST/DBNAME?sslmode=require
#
# In Neon: Project → Connect → pick **Postgres** connection (URI / psql). The host often looks like
# ep-….neon.tech (not …apirest….neon.tech). Paste the full string below; URL-encode special chars in the password.
DATABASE_URL=postgresql://neondb_owner:npg_yM01rKEpCULB@ep-hidden-moon-alscwnpy-pooler.c-3.eu-central-1.aws.neon.tech/Electric%20Micro-Mobility%20Platform?sslmode=require&channel_binding=require

# JWT signing (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# Comma-separated origins for CORS (Expo web, local dev)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081
